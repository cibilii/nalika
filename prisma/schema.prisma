generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("postgresql://postgres.uovjrezgcgombjczotgg:52hHNqCSD%2F6QNMr@aws-0-eu-west-1.pooler.supabase.com:5432/postgres?pgbouncer=true&connection_limit=1")
}

model Customer {
  id        Int       @id @default(autoincrement())
  firstName String
  lastName  String
  phone     String    @unique
  bookings  Booking[]
}

model Service {
  id        Int       @id @default(autoincrement())
  name      String
  price     Float
  duration  Int
  category  String
  bookings  Booking[]
}

model Portfolio {
  id        Int    @id @default(autoincrement())
  title     String
  imageUrl  String
  category  String
}

model Booking {
  id              Int      @id @default(autoincrement())
  trackingNumber  String   @unique
  date            String
  slot            String
  status          String   @default("CONFIRMED")
  createdAt       DateTime @default(now())
  customerId      Int
  serviceId       Int
  customer        Customer @relation(fields: [customerId], references: [id])
  service         Service  @relation(fields: [serviceId], references: [id])
}